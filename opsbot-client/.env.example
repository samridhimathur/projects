# OpsBot Client Configuration

# Client Identity
OPSBOT_CLIENT_SOURCE=dev-machine-01
OPSBOT_ENVIRONMENT=dev

# Cloud API Endpoint
OPSBOT_CLOUD_URL=http://localhost:8080
OPSBOT_INGESTION_PATH=/api/ingest

# Retry Configuration
OPSBOT_RETRY_MAX_ATTEMPTS=3
OPSBOT_RETRY_BACKOFF_SECONDS=2

# Local Buffer
OPSBOT_BUFFER_DB=./opsbot_buffer.db

# Rules Configuration
OPSBOT_RULES_CONFIG=./rules.json

# Monitoring
OPSBOT_CHECK_INTERVAL_SECONDS=30

# Logging
OPSBOT_LOG_LEVEL=INFO

# API Keys (for MCP tools if needed)
# ANTHROPIC_API_KEY=sk-xxx
# COHERE_API_KEY=xxx

